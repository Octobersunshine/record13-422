PORT=3000

API_KEY=your-secret-api-key

CDN_PROVIDER=aliyun

CDN_ACCESS_KEY_ID=your-access-key-id
CDN_ACCESS_KEY_SECRET=your-access-key-secret

CDN_ENDPOINT=cdn.aliyuncs.com

CDN_DOMAIN=cdn.example.com

CLOUDFLARE_ZONE_ID=your-cloudflare-zone-id

PURGE_MAX_RETRIES=3
PURGE_RETRY_BASE_DELAY=1000
PURGE_RETRY_BACKOFF_FACTOR=2
PURGE_REQUEST_TIMEOUT=10000
PURGE_RECORD_DIR=./records
PURGE_MAX_RECORDS=10000
